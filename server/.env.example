# Adres URL ESP32 (bez trailing slash)
ESP_URL=http://192.168.1.50

# Port backendu (Vite proxyuje /api tu)
PORT=4000

# Sciezka do bazy SQLite (domyslnie ./data.db)
DB_PATH=./data.db

# Haslo do panelu operatora (Chronione GET/POST). Zmien przed produkcja.
OPERATOR_PASSWORD=admin

# Token do ESP32 – MUSI zgadzac sie z API_TOKEN w ESP/1z9-ESP/src/main.cpp.
# Chroni ESP przed komendami z innych urzadzen w tej samej sieci.
ESP_API_TOKEN=1z9-esp-token
